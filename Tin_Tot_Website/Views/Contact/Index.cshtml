@model Tin_Tot_Website.Models.ContactPageViewModel
@{
    ViewData["Title"] = "Liên hệ";
}

<section class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h1 class="h4 fw-bold mb-3">Liên hệ</h1>
                <p class="text-muted">Vui lòng điền thông tin, hệ thống sẽ gửi về email hỗ trợ của chúng tôi.</p>

                @if (TempData["ContactSuccess"] is string message)
                {
                    <div class="alert alert-success">@message</div>
                }

                <form method="post" asp-action="Index" asp-controller="Contact" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="SenderEmail" class="form-label">Email (người gửi)</label>
                        <input asp-for="SenderEmail" class="form-control" type="email" placeholder="example@gmail.com" />
                        <span asp-validation-for="SenderEmail" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Issue" class="form-label"></label>
                        <textarea asp-for="Issue" class="form-control" rows="5" placeholder="Mô tả vấn đề bạn cần liên hệ"></textarea>
                        <span asp-validation-for="Issue" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Gửi liên hệ</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

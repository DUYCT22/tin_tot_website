@model TinTot.Application.DTOs.HomePageDto
@{
    ViewData["Title"] = "Trang chủ";

}

<section class="hero-bg p-4 p-md-5 mb-4">
    <div class="row align-items-center gy-3">
        <div class="col-lg-12">
            <h1 class="display-6 fw-bold mb-2">Tin Tốt - Rao vặt an toàn, nhanh chóng</h1>
            <p class="text-muted mb-0">Khám phá danh mục nổi bật và các bài đăng mới nhất được gợi ý cho bạn.</p>
        </div>
    </div>
</section>

@if (Model.Banners.Count > 0)
{
    <div id="homeBanners" class="carousel slide carousel-fade mb-4" data-bs-ride="carousel">
        <div class="carousel-indicators">
            @for (var i = 0; i < Model.Banners.Count; i++)
            {
                <button type="button" data-bs-target="#homeBanners" data-bs-slide-to="@i" class="@(i == 0 ? "active" : string.Empty)"></button>
            }
        </div>

        <div class="carousel-inner rounded-4 shadow-sm">
            @for (var i = 0; i < Model.Banners.Count; i++)
            {
                var banner = Model.Banners[i];
                <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                    <a href="@(string.IsNullOrWhiteSpace(banner.Link) ? "#" : banner.Link)" target="_blank" rel="noopener noreferrer">
                        <img src="@(banner.Image ?? "/favicon.ico")" class="d-block w-100" style="height:320px; object-fit:cover;" alt="Banner @i" />
                    </a>
                </div>
            }
        </div>
    </div>
}

    <section class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 fw-bold mb-0">Danh mục nổi bật</h2>
            <span class="text-muted small">@Model.Categories.Count danh mục</span>
        </div>

    <div class="row g-3 justify-content-center text-center">
            @foreach (var category in Model.Categories)
            {
            
                <a class="col-6 col-sm-4 col-md-3 col-lg-2 mb-3 text-center d-flex flex-column align-items-center" href="#" style="height:fit-content; text-decoration:none">
                    <img src="@(category.Image ?? "/favicon.ico")" class="mb-2 shadow-sm hover-zoom" style="width: 100px; height: 100px; object-fit:cover; border-radius: 10px;" alt="@category.Name" />
                            <p class="card-text text-dark text-center fw-semibold mb-0">@category.Name</p>
                    </a>
            }
        </div>
    </section>

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 fw-bold mb-0">Bài đăng mới nhất</h2>
        <a class="text-primary small text-decoration-none mt-2 mt-md-0" href="@Url.Action("AllListings", "Home")">Xem tất cả →</a>
    </div>

    @await Html.PartialAsync("~/Views/Shared/Components/_ListingCardGrid.cshtml", new Tin_Tot_Website.Models.ListingCardSectionViewModel
    {
        Listings = Model.Listings,
        UserRatingAvg = Model.UserRatingAvg,
        EmptyMessage = "Chưa có bài đăng mới nhất."
        })
</section>
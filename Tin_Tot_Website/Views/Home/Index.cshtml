@model TinTot.Application.DTOs.HomePageDto
@{
    ViewData["Title"] = "Trang chủ";

    string ToSlug(string? input)
    {
        if (string.IsNullOrWhiteSpace(input))
        {
            return "tin-dang";
        }

        var normalized = input.Trim().ToLowerInvariant();
        var sb = new System.Text.StringBuilder();

        foreach (var c in normalized.Normalize(System.Text.NormalizationForm.FormD))
        {
            var uc = System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c);
            if (uc == System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                continue;
            }

            if (char.IsLetterOrDigit(c))
            {
                sb.Append(c == 'đ' ? 'd' : c);
            }
            else if (char.IsWhiteSpace(c) || c is '-' or '_' or '.')
            {
                sb.Append('-');
            }
        }

        var slug = sb.ToString().Trim('-');
        while (slug.Contains("--"))
        {
            slug = slug.Replace("--", "-");
        }

        return string.IsNullOrWhiteSpace(slug) ? "tin-dang" : slug;
    }
}

<section class="hero-bg p-4 p-md-5 mb-4">
    <div class="row align-items-center gy-3">
        <div class="col-lg-8">
            <h1 class="display-6 fw-bold mb-2">Tin Tốt - Rao vặt an toàn, nhanh chóng</h1>
            <p class="text-muted mb-0">Khám phá danh mục nổi bật và các bài đăng mới nhất được gợi ý cho bạn.</p>
        </div>
        <div class="col-lg-4 text-lg-end">
            <a class="btn btn-primary btn-lg" href="/Trang-Chu">Trang chủ friendly link</a>
        </div>
    </div>
</section>

@if (Model.Banners.Count > 0)
{
    <div id="homeBanners" class="carousel slide carousel-fade mb-4" data-bs-ride="carousel">
        <div class="carousel-indicators">
            @for (var i = 0; i < Model.Banners.Count; i++)
            {
                <button type="button" data-bs-target="#homeBanners" data-bs-slide-to="@i" class="@(i == 0 ? "active" : string.Empty)"></button>
            }
        </div>

        <div class="carousel-inner rounded-4 shadow-sm">
            @for (var i = 0; i < Model.Banners.Count; i++)
            {
                var banner = Model.Banners[i];
                <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                    <a href="@(string.IsNullOrWhiteSpace(banner.Link) ? "#" : banner.Link)" target="_blank" rel="noopener noreferrer">
                        <img src="@(banner.Image ?? "/favicon.ico")" class="d-block w-100" style="height:320px; object-fit:cover;" alt="Banner @i" />
                    </a>
                </div>
            }
        </div>
    </div>
}

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 fw-bold mb-0">Danh mục nổi bật</h2>
        <span class="text-muted small">@Model.Categories.Count danh mục</span>
    </div>

    <div class="row g-3">
        @foreach (var category in Model.Categories)
        {
            <div class="col-6 col-md-4 col-lg-2">
                <a class="card h-100 border-0 shadow-sm text-decoration-none" href="#">
                    <img src="@(category.Image ?? "/favicon.ico")" class="card-img-top" style="height:100px; object-fit:cover;" alt="@category.Name" />
                    <div class="card-body py-2">
                        <p class="card-text text-dark text-center fw-semibold mb-0">@category.Name</p>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 fw-bold mb-0">Bài đăng mới nhất</h2>
        <span class="text-muted small">@Model.Listings.Count bài đăng</span>
    </div>

    <div class="row g-3">
        @foreach (var listing in Model.Listings)
        {
            var avg = listing.UserId.HasValue && Model.UserRatingAvg.TryGetValue(listing.UserId.Value, out var value) ? value : 0;
            var full = (int)Math.Floor(avg);
            <div class="col-6 col-md-4 col-lg-2 d-flex">
                <a class="card h-100 w-100 border-0 shadow-sm text-decoration-none" href="/Bai-dang/@ToSlug(listing.Title)-@listing.Id">
                    <img src="@(listing.FirstImageUrl ?? "/favicon.ico")" class="card-img-top" style="height:140px; object-fit:cover;" alt="@listing.Title" />
                    <div class="card-body">
                        <h3 class="h6 text-dark text-truncate">@listing.Title</h3>
                        <p class="text-danger fw-bold mb-2">@string.Format("{0:N0} đ", listing.Price ?? 0)</p>
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <img src="@(listing.UserAvatar ?? "/favicon.ico")" class="rounded-circle border" style="width:28px;height:28px;object-fit:cover" alt="avatar" />
                            <div class="small text-warning">
                                @for (var i = 0; i < full && i < 5; i++)
                                {
                                    <span>★</span>
                                }
                                @for (var i = full; i < 5; i++)
                                {
                                    <span class="text-secondary">☆</span>
                                }
                            </div>
                        </div>
                        <p class="small text-muted mb-0">@(listing.CreatedAt?.ToString("dd/MM/yyyy") ?? string.Empty)</p>
                    </div>
                </a>
            </div>
        }
    </div>
</section>
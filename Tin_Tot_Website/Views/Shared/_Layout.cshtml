<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tin Tốt</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Tin_Tot_Website.styles.css" asp-append-version="true" />
    <style>
        .navbar-brand-logo {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            object-fit: cover;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
        }

        .hero-bg {
            background: linear-gradient(135deg, #fffde7, #fef3c7);
            border: 1px solid #f6e8a6;
            border-radius: 1rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <h2 class="fw-bold">Tin Tốt</h2>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Chính sách</a></li>
                    </ul>
                    <div id="guestActions" class="d-flex gap-2">
                        <a class="btn btn-outline-primary" href="/login">Đăng nhập</a>
                        <a class="btn btn-primary" href="/register">Đăng ký</a>
                    </div>

                    <div id="userActions" class="dropdown d-none">
                        <button class="btn btn-light border dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-expanded="false">
                            <img id="userAvatar" class="user-avatar" src="/favicon.ico" alt="Avatar" />
                            <span id="userName" class="fw-semibold"></span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li><span class="dropdown-item-text text-muted small">Đã đăng nhập</span></li>
                            <li><a class="dropdown-item" asp-controller="MemberListing" asp-action="Profile"><i class="bi bi-person-circle me-2"></i>Trang cá nhân</a></li>
                            <li><a class="dropdown-item" asp-controller="MemberListing" asp-action="Post"><i class="bi bi-pencil-square me-2"></i>Đăng tin</a></li>
                            <li><a class="dropdown-item" asp-controller="MemberListing" asp-action="Saved"><i class="bi bi-heart me-2"></i>Tin đã lưu</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><button id="logoutBtn" class="dropdown-item text-danger" type="button"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top py-3 mt-4 bg-light">
        <div class="container d-flex justify-content-between flex-wrap gap-2 text-muted small">
            <span>© 2026 Tin Tốt</span>
            <span>Nền tảng mua bán đơn giản, an toàn.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (() => {
            const tokenKey = 'tin_tot_token';
            const profileKey = 'tin_tot_user';
            const guestActions = document.getElementById('guestActions');
            const userActions = document.getElementById('userActions');
            const userName = document.getElementById('userName');
            const userAvatar = document.getElementById('userAvatar');
            const logoutBtn = document.getElementById('logoutBtn');

             const writeAuthCookie = (value) => {
                document.cookie = `tin_tot_access_token=${encodeURIComponent(value)}; path=/; SameSite=Lax`;
            };

            const clearAuthCookie = () => {
                document.cookie = 'tin_tot_access_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax';
            };

            const token = localStorage.getItem(tokenKey);
            const rawProfile = localStorage.getItem(profileKey);

            if (token) {
                writeAuthCookie(token);
            } else {
                clearAuthCookie();
            }

            if (token && rawProfile) {
                try {
                    const profile = JSON.parse(rawProfile);
                    userName.textContent = profile.loginName || profile.fullName || 'Tài khoản';
                    if (profile.avatar) {
                        userAvatar.src = profile.avatar;
                    }

                    guestActions.classList.add('d-none');
                    userActions.classList.remove('d-none');
                } catch {
                    localStorage.removeItem(profileKey);
                    localStorage.removeItem(tokenKey);
                    clearAuthCookie();
                }
            }

            logoutBtn?.addEventListener('click', async () => {
                const activeToken = localStorage.getItem(tokenKey);

                try {
                    if (activeToken) {
                        await fetch('/api/user/logout', {
                            method: 'POST',
                            headers: {
                                Authorization: `Bearer ${activeToken}`
                            }
                        });
                    }
                } finally {
                    localStorage.removeItem(tokenKey);
                    localStorage.removeItem(profileKey);
                    clearAuthCookie();
                    window.location.href = '/';
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@using TinTot.Application.Interfaces.Home
@inject IHomeReadRepository HomeReadRepository
@{
    var navbarSelectedCategoryIdRaw = Context.Request.Query["categoryId"].ToString();
    var navbarSelectedKeyword = Context.Request.Query["keyword"].ToString();
    var navbarCategories = await HomeReadRepository.GetAllCategoriesAsync();
    var navbarCategoryById = navbarCategories.ToDictionary(x => x.Id);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tin Tốt</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Tin_Tot_Website.styles.css" asp-append-version="true" />
    <style>
        .search-box {
            border: 2px solid #ccc;
            border-radius: 50px;
            overflow: hidden;
            background-color: #fff;
        }

            .search-box select,
            .search-box input {
                border: none !important; /* bỏ viền mặc định */
                box-shadow: none !important;
            }

            .search-box .input-group-text {
                background-color: transparent;
                font-weight: bold;
                color: #999;
            }

        #guestActions a {
            transition: color 0.2s ease;
        }

            #guestActions a:hover {
                color: black !important;
            }
        .navbar {
            transition: all 0.3s ease;
        }

        .navbar-brand-logo {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            object-fit: cover;
        }

        .search-bar input {
            border-radius: 50px !important;
            padding-left: 1rem;
        }

        .search-bar .input-group-text {
            border-radius: 50px 0 0 50px;
        }

        .navbar .btn {
            transition: all 0.3s ease;
        }

            .navbar .btn:hover {
                transform: translateY(-2px);
            }


        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
        }

        .hero-bg {
            background: linear-gradient(135deg, #fffde7, #fef3c7);
            border: 1px solid #f6e8a6;
            border-radius: 1rem;
        }

        .message-popup {
            width: min(92vw, 680px);
            max-height: 75vh;
        }

        .message-conversations {
            width: 240px;
            max-height: 58vh;
            overflow-y: auto;
            border-right: 1px solid #e9ecef;
        }

        .message-chat {
            flex: 1;
            min-width: 0;
        }

        .message-chat-body {
            height: 44vh;
            overflow-y: auto;
            overflow-x: hidden;
            background: #f8f9fa;
        }

        .message-bubble-content {
            white-space: pre-wrap;
            overflow-wrap: anywhere;
            word-break: break-word;
        }

        @@media (max-width: 991.98px) {
            .message-popup {
                width: min(96vw, 680px);
            }

            .message-conversations {
                width: 190px;
            }
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <h2 class="fw-bold">Tin Tốt</h2>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

               
                    <div class="collapse navbar-collapse" id="mainNav">
                    <form class="search-form d-flex flex-grow-1 me-lg-3" method="get" asp-controller="Home" asp-action="AllListings">
                        <div class="input-group search-box" style="max-width: 600px;">
                            <select class="form-select border-0" name="categoryId" style="max-width: 220px;">
                                <option value="">Tất cả danh mục</option>

                                @foreach (var parent in navbarCategories.Where(c => !c.ParentId.HasValue))
                                {
                                    <!-- Danh mục cha -->
                                    <option value="@parent.Id"
                                            selected="@(navbarSelectedCategoryIdRaw == parent.Id.ToString() ? "selected" : null)">
                                        @parent.Name
                                    </option>

                                    <!-- Danh mục con -->
                                    @foreach (var child in navbarCategories.Where(c => c.ParentId == parent.Id))
                                    {
                                        <option value="@child.Id"
                                                selected="@(navbarSelectedCategoryIdRaw == child.Id.ToString() ? "selected" : null)">
                                            &nbsp;&nbsp;— @child.Name
                                        </option>
                                    }
                                }
                            </select>


                            <span class="input-group-text border-0 bg-white">|</span>

                            <div class="position-relative flex-grow-1">
                                <input class="form-control border-0 pe-5" type="search" name="keyword" value="@navbarSelectedKeyword" placeholder="Tìm kiếm bài đăng..." autocomplete="off" />
                                <button type="submit" class="btn btn-link position-absolute end-0 top-0 mt-1 me-2 text-secondary">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>
                    </form>

                    @* <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Chính sách</a></li>
                    </ul> *@
                    <div id="guestActions" class="d-flex gap-2 ms-auto align-items-center">
                        <a class="nav-link text-warning fw-bold" href="/Dang-nhap">Đăng nhập</a>
                        <span>|</span>
                        <a class="nav-link text-warning fw-bold" href="/Dang-ky">Đăng ký</a>
                    </div>

                    <div id="messageActions" class="dropdown d-none me-2">
                        <button class="btn btn-light border position-relative" id="messageBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" title="Tin nhắn" type="button">
                            <i class="bi bi-chat-dots"></i>
                            <span id="messageBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-0 message-popup">
                            <div class="px-3 py-2 border-bottom">
                                <strong>Tin nhắn</strong>
                            </div>
                            <div class="d-flex">
                                <div id="popupConversationList" class="list-group list-group-flush message-conversations"></div>
                                <div class="message-chat d-flex flex-column">
                                    <div id="popupChatHeader" class="px-3 py-2 border-bottom text-muted">Chọn cuộc trò chuyện</div>
                                    <div id="popupChatBody" class="p-3 message-chat-body"></div>
                                    <div class="px-3 pt-1 pb-0 border-top">
                                        <small id="typingIndicator" class="text-muted d-none">Đang nhập tin nhắn...</small>
                                    </div>
                                    <div class="p-2">
                                        <div class="input-group">
                                            <input id="popupChatInput" type="text" class="form-control" placeholder="Nhập tin nhắn..." />
                                            <button id="popupSendBtn" type="button" class="btn btn-primary">Gửi</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="notificationActions" class="dropdown d-none me-2">
                        <button class="btn btn-light border position-relative" id="notificationBtn" data-bs-toggle="dropdown" aria-expanded="false" title="Thông báo" type="button">
                            <i class="bi bi-bell"></i>
                            <span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-0" style="width: 360px; max-width: 90vw;">
                            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                <strong>Thông báo</strong>
                                <button id="markAllReadBtn" class="btn btn-link btn-sm text-decoration-none" type="button">Đánh dấu đã đọc</button>
                            </div>
                            <div id="notificationListContainer" style="max-height: 360px; overflow-y: auto;"></div>
                        </div>
                    </div>
                    <div id="userActions" class="dropdown d-none">
                        <button class="btn btn-light border dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown" aria-expanded="false">
                            <img id="userAvatar" class="user-avatar" src="/favicon.ico" alt="Avatar" />
                            <span id="userName" class="fw-semibold"></span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li><span class="dropdown-item-text text-muted small">Đã đăng nhập</span></li>
                            <li><a class="dropdown-item" asp-controller="MemberListing" asp-action="Profile"><i class="bi bi-person-circle me-2"></i>Trang cá nhân</a></li>
                            <li><a class="dropdown-item" asp-controller="Messages" asp-action="Index"><i class="bi bi-chat-dots me-2"></i>Tin nhắn</a></li>
                            <li><a class="dropdown-item" asp-controller="MemberListing" asp-action="Post"><i class="bi bi-pencil-square me-2"></i>Đăng tin</a></li>
                            <li><a class="dropdown-item" asp-controller="MemberListing" asp-action="Saved"><i class="bi bi-heart me-2"></i>Tin đã lưu</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><button id="logoutBtn" class="dropdown-item text-danger" type="button"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="bg-light border-top pt-4 pb-2 mt-5">
        <div class="container">
            <div class="row gy-4">
                <div class="col-md-4">
                    <img src="~/images/Logo.jpg" alt="Logo" class="img-fluid mb-2 rounded-circle" style="max-height: 100px;" />
                    <p class="small text-muted">
                        Nền tảng mua bán đáng tin cậy. Chúng tôi kết nối người mua và người bán một cách nhanh chóng, an toàn và thuận tiện.
                    </p>
                </div>

                <div class="col-6 col-md-2">
                    <h6 class="text-uppercase fw-bold">Trang</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">Trang chủ</a></li>
                        <li><a asp-controller="Home" asp-action="AllListings" class="text-muted text-decoration-none">Tin đăng</a></li>
                    </ul>
                </div>

                <div class="col-6 col-md-3">
                    <h6 class="text-uppercase fw-bold">Hỗ trợ</h6>
                    <ul class="list-unstyled small">
                        <li>
                            <a asp-controller="Home" asp-action="TermsofUse" class="text-muted text-decoration-none">Điều khoản sử dụng</a>
                        </li>
                        <li><a asp-controller="Home" asp-action="About" class="text-muted text-decoration-none">Về chúng tôi</a></li>
                        <li><a asp-controller="Contact" asp-action="Index" class="text-muted text-decoration-none">Liên hệ</a></li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h6 class="text-uppercase fw-bold">Theo dõi chúng tôi</h6>
                    <a href="https://fb.com/NhutDuyOt" class="text-muted me-2"><i class="bi bi-facebook fs-5"></i></a>
                </div>
            </div>

            <hr class="border-secondary my-3" />

            <div class="text-center small text-muted">
                &copy; 2026 Tin Tốt. Mọi bản quyền thuộc Nguyễn Nhựt Duy.
            </div>
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (async () => {
            const tokenKey = 'tin_tot_token';
            const profileKey = 'tin_tot_user';
            const guestActions = document.getElementById('guestActions');
            const userActions = document.getElementById('userActions');
            const notificationActions = document.getElementById('notificationActions');
            const messageActions = document.getElementById('messageActions');
            const notificationBtn = document.getElementById('notificationBtn');
            const notificationBadge = document.getElementById('notificationBadge');
            const notificationListContainer = document.getElementById('notificationListContainer');
            const markAllReadBtn = document.getElementById('markAllReadBtn');
            const messageBtn = document.getElementById('messageBtn');
            const messageBadge = document.getElementById('messageBadge');
            const popupConversationList = document.getElementById('popupConversationList');
            const popupChatHeader = document.getElementById('popupChatHeader');
            const popupChatBody = document.getElementById('popupChatBody');
            const popupChatInput = document.getElementById('popupChatInput');
            const popupSendBtn = document.getElementById('popupSendBtn');
            const typingIndicator = document.getElementById('typingIndicator');
            const userName = document.getElementById('userName');
            const userAvatar = document.getElementById('userAvatar');
            const logoutBtn = document.getElementById('logoutBtn');

             const writeAuthCookie = (value) => {
                document.cookie = `tin_tot_access_token=${encodeURIComponent(value)}; path=/; SameSite=Lax`;
            };

            const clearAuthCookie = () => {
                document.cookie = 'tin_tot_access_token=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax';
            };

            const token = localStorage.getItem(tokenKey);
            const rawProfile = localStorage.getItem(profileKey);

            if (token) {
                writeAuthCookie(token);
            } else {
                clearAuthCookie();
            }

            if (token && rawProfile) {
                try {
                    const profile = JSON.parse(rawProfile);
                    userName.textContent = profile.loginName || profile.fullName || 'Tài khoản';
                    if (profile.avatar) {
                        userAvatar.src = profile.avatar;
                    }

                    guestActions.classList.add('d-none');
                    userActions.classList.remove('d-none');
                    notificationActions.classList.remove('d-none');
                    messageActions.classList.remove('d-none');

                    const myProfile = JSON.parse(localStorage.getItem(profileKey) || '{}');
                    const myUserId = Number(myProfile.id || 0);
                    let selectedReceiverKey = null;
                    let selectedReceiverId = null;
                    let unreadMessageCount = 0;
                    const unreadConversationSet = new Set();
                    let typingTimeout = null;

                    const setMessageBadge = () => {
                        messageBadge.textContent = unreadMessageCount;
                        messageBadge.classList.toggle('d-none', unreadMessageCount <= 0);
                    };

                    const playTingTing = () => {
                        const Ctx = window.AudioContext || window.webkitAudioContext;
                        if (!Ctx) return;

                        const ctx = new Ctx();
                        const playOne = (freq, offsetMs) => {
                            const osc = ctx.createOscillator();
                            const gain = ctx.createGain();
                            osc.type = 'sine';
                            osc.frequency.value = freq;
                            osc.connect(gain);
                            gain.connect(ctx.destination);

                            const start = ctx.currentTime + (offsetMs / 1000);
                            gain.gain.setValueAtTime(0.0001, start);
                            gain.gain.exponentialRampToValueAtTime(0.18, start + 0.02);
                            gain.gain.exponentialRampToValueAtTime(0.0001, start + 0.22);
                            osc.start(start);
                            osc.stop(start + 0.24);
                        };

                        playOne(880, 0);
                        playOne(1175, 170);
                        setTimeout(() => ctx.close(), 500);
                    };

                    const authHeaders = () => ({ 'Content-Type': 'application/json', Authorization: `Bearer ${token}` });

                    const timeFmt = (v) => {
                        if (!v) return '';
                        const d = new Date(v);
                        if (Number.isNaN(d.getTime())) return '';
                        return d.toLocaleString('vi-VN', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' });
                    };

                    const loadMessageConversations = async () => {
                        const resp = await fetch('/api/messages/conversations', { headers: authHeaders() });
                        if (!resp.ok) return;
                        const json = await resp.json();
                        if (!json.success) return;

                        popupConversationList.innerHTML = '';
                        json.data.forEach(x => {
                            const el = document.createElement('button');
                            el.type = 'button';
                            el.className = 'list-group-item list-group-item-action';
                            if (unreadConversationSet.has(x.receiverKey)) {
                                el.classList.add('fw-semibold');
                            }
                            el.dataset.receiverKey = x.receiverKey;
                            el.dataset.receiverId = x.receiverId;
                            el.dataset.receiverName = x.displayName;
                            el.innerHTML = `<div class='text-truncate'>${x.displayName}</div><small class='text-muted text-truncate d-block'>${x.lastMessage || ''}</small>`;
                            el.onclick = () => selectConversation(x.receiverKey, x.displayName, Number(x.receiverId));
                            popupConversationList.appendChild(el);
                        });
                    };

                    const renderChatMessage = (m) => {
                        const isSelf = Number(m.senderId) === myUserId;
                        const wrap = document.createElement('div');
                        wrap.className = `mb-2 d-flex ${isSelf ? 'justify-content-end' : 'justify-content-start'}`;

                        const bubble = document.createElement('div');
                        bubble.className = `p-2 rounded ${isSelf ? 'bg-primary text-white' : 'bg-white border'}`;
                        bubble.style.maxWidth = '78%';
                        bubble.innerHTML = `<div class='message-bubble-content'>${(m.content || '').replace(/</g, '&lt;')}</div><small class='opacity-75'>${timeFmt(m.sentAt)}</small>`;

                        wrap.appendChild(bubble);
                        popupChatBody.appendChild(wrap);
                    };

                    const loadMessageHistory = async () => {
                        if (!selectedReceiverKey) return;
                        const resp = await fetch(`/api/messages/history/${encodeURIComponent(selectedReceiverKey)}`, { headers: authHeaders() });
                        if (!resp.ok) return;
                        const json = await resp.json();
                        if (!json.success) return;

                        popupChatBody.innerHTML = '';
                        json.data.forEach(renderChatMessage);
                        popupChatBody.scrollTop = popupChatBody.scrollHeight;
                    };

                    const selectConversation = async (receiverKey, receiverName, receiverId) => {
                        selectedReceiverKey = receiverKey;
                        selectedReceiverId = receiverId;
                        popupChatHeader.textContent = `Đang chat với ${receiverName}`;
                        typingIndicator.classList.add('d-none');

                        if (unreadConversationSet.delete(receiverKey)) {
                            unreadMessageCount = Math.max(0, unreadMessageCount - 1);
                            setMessageBadge();
                        }

                        await loadMessageConversations();
                        await loadMessageHistory();
                    };

                    const sendPopupMessage = async () => {
                        if (!selectedReceiverKey) return;
                        const content = (popupChatInput.value || '').trim();
                        if (!content) return;

                        const resp = await fetch('/api/messages/send', {
                            method: 'POST',
                            headers: authHeaders(),
                            body: JSON.stringify({ receiverKey: selectedReceiverKey, content })
                        });
                        const json = await resp.json();
                        if (!resp.ok || !json.success) {
                            alert(json.message || 'Gửi tin nhắn thất bại.');
                            return;
                        }

                        popupChatInput.value = '';
                        await loadMessageConversations();
                        await loadMessageHistory();
                    };

                    popupSendBtn?.addEventListener('click', sendPopupMessage);
                    popupChatInput?.addEventListener('keypress', (e) => {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            sendPopupMessage();
                        }
                    });

                    const setUnreadBadge = (count) => {
                        notificationBadge.textContent = count;
                        notificationBadge.classList.toggle('d-none', !count || count <= 0);
                    };

                    const refreshUnreadCount = async () => {
                        const resp = await fetch('/api/notifications/unread-count', { headers: { Authorization: `Bearer ${token}` } });
                        if (!resp.ok) return;
                        const data = await resp.json();
                        setUnreadBadge(data.unreadCount || 0);
                    };

                    const loadNotificationList = async () => {
                        const resp = await fetch('/api/notifications/list', { headers: { Authorization: `Bearer ${token}` } });
                        if (!resp.ok) return;
                        notificationListContainer.innerHTML = await resp.text();
                    };

                    notificationBtn?.addEventListener('click', async () => {
                        await loadNotificationList();
                    });

                    markAllReadBtn?.addEventListener('click', async () => {
                        const resp = await fetch('/api/notifications/mark-all-read', {
                            method: 'POST',
                            headers: { Authorization: `Bearer ${token}` }
                        });
                        if (!resp.ok) return;
                        await loadNotificationList();
                        setUnreadBadge(0);
                    });

                    await refreshUnreadCount();

                    await loadMessageConversations();

                    messageBtn?.addEventListener('click', async () => {
                        await loadMessageConversations();
                        if (selectedReceiverKey) await loadMessageHistory();
                    });

                    const connection = new signalR.HubConnectionBuilder()
                        .withUrl('/hubs/notifications')
                        .withAutomaticReconnect()
                        .build();

                    connection.on('ReceiveNotification', (payload) => {
                        const count = payload?.unreadCount ?? 0;
                        setUnreadBadge(count);
                    });

                    const messageConnection = new signalR.HubConnectionBuilder()
                        .withUrl('/hubs/messages')
                        .withAutomaticReconnect()
                        .build();

                    messageConnection.on('ReceiveMessage', async (payload) => {
                        await loadMessageConversations();

                        const senderId = Number(payload?.senderId || 0);
                        const receiverKeyOfSender = popupConversationList
                            .querySelector(`[data-receiver-id='${senderId}']`)
                            ?.dataset?.receiverKey;

                        if (selectedReceiverKey && (senderId === selectedReceiverId || Number(payload?.receiverId || 0) === selectedReceiverId)) {
                            await loadMessageHistory();
                        }

                        if (senderId && senderId !== myUserId && receiverKeyOfSender && receiverKeyOfSender !== selectedReceiverKey) {
                            if (!unreadConversationSet.has(receiverKeyOfSender)) {
                                unreadConversationSet.add(receiverKeyOfSender);
                                unreadMessageCount += 1;
                                setMessageBadge();
                            }
                            playTingTing();
                        }
                    });

                    messageConnection.on('TypingStatusChanged', (payload) => {
                        const senderId = Number(payload?.senderId || 0);
                        const isTyping = !!payload?.isTyping;
                        const show = !!selectedReceiverId && senderId === selectedReceiverId && isTyping;
                        typingIndicator.classList.toggle('d-none', !show);
                    });

                    popupChatInput?.addEventListener('input', () => {
                        if (!selectedReceiverId) return;
                        messageConnection.invoke('NotifyTyping', selectedReceiverId, true).catch(() => {});
                        clearTimeout(typingTimeout);
                        typingTimeout = setTimeout(() => {
                            messageConnection.invoke('NotifyTyping', selectedReceiverId, false).catch(() => {});
                        }, 1400);
                    });

                    messageConnection.start().catch(() => {});
                } catch {
                    localStorage.removeItem(profileKey);
                    localStorage.removeItem(tokenKey);
                    clearAuthCookie();
                }
            }

            logoutBtn?.addEventListener('click', async () => {
                const activeToken = localStorage.getItem(tokenKey);

                try {
                    if (activeToken) {
                        await fetch('/api/user/logout', {
                            method: 'POST',
                            headers: {
                                Authorization: `Bearer ${activeToken}`
                            }
                        });
                    }
                } finally {
                    localStorage.removeItem(tokenKey);
                    localStorage.removeItem(profileKey);
                    clearAuthCookie();
                    window.location.href = '/';
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #fef9c3, #fef3c7);
        }

        .auth-card {
            max-width: 460px;
            border: 0;
            border-radius: 20px;
        }

        .logo {
            width: 72px;
            height: 72px;
            object-fit: contain;
        }

        .input-icon {
            position: absolute;
            top: 50%;
            right: 1rem;
            transform: translateY(-50%);
            cursor: pointer;
            color: #64748b;
        }
    </style>
</head>
<body class="d-flex align-items-center py-4">
    <div class="container">
        <div class="card shadow-lg mx-auto auth-card p-4 p-md-5">
            <div class="text-center mb-4">
                <img src="~/favicon.ico" alt="Logo" class="logo mb-3" />
                <h1 class="h4 fw-bold mb-1">Đăng nhập</h1>
                <p class="text-muted mb-0">Chào mừng bạn quay lại Tin Tốt</p>
            </div>

            <form id="loginForm">
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập</label>
                    <input id="loginName" class="form-control form-control-lg" placeholder="vd: nguyenvana" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <div class="position-relative">
                        <input id="passwordInput" type="password" class="form-control form-control-lg pe-5" placeholder="Nhập mật khẩu" required />
                        <i id="togglePassword" class="fa-regular fa-eye input-icon"></i>
                    </div>
                </div>

                <button id="loginButton" type="submit" class="btn btn-primary btn-lg w-100">Đăng nhập</button>
            </form>

            <p class="text-center mt-4 mb-0">
                Chưa có tài khoản?
                <a class="fw-semibold text-decoration-none" href="/register">Đăng ký ngay</a>
            </p>
        </div>
    </div>

    <script>
        const togglePassword = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('passwordInput');
        togglePassword.addEventListener('click', () => {
            passwordInput.type = passwordInput.type === 'password' ? 'text' : 'password';
            togglePassword.classList.toggle('fa-eye');
            togglePassword.classList.toggle('fa-eye-slash');
        });

        document.getElementById('loginForm').addEventListener('submit', async (event) => {
            event.preventDefault();
            const btn = document.getElementById('loginButton');
            const original = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const response = await fetch('/api/user/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        loginName: document.getElementById('loginName').value,
                        password: passwordInput.value
                    })
                });

                const data = await response.json();
                if (response.ok && data.success) {
                    const token = data.token ?? '';
                    localStorage.setItem('tin_tot_token', token);
                    document.cookie = `tin_tot_access_token=${encodeURIComponent(token)}; path=/; SameSite=Lax`;
                    if (data.user) {
                        localStorage.setItem('tin_tot_user', JSON.stringify(data.user));
                    }

                    await Swal.fire({ icon: 'success', text: data.message ?? 'Đăng nhập thành công', timer: 1400, showConfirmButton: false });
                    window.location.href = data.redirectUrl ?? '/';
                    return;
                }

                Swal.fire({ icon: 'error', text: data.message ?? 'Đăng nhập thất bại.' });
            } catch {
                Swal.fire({ icon: 'error', text: 'Có lỗi xảy ra. Vui lòng thử lại.' });
            } finally {
                btn.disabled = false;
                btn.innerHTML = original;
            }
        });
    </script>
</body>
</html>
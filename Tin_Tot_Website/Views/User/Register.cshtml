@{
    ViewData["Title"] = "Đăng ký";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #fef9c3, #fef3c7);
        }

        .auth-card {
            max-width: 700px;
            border: 0;
            border-radius: 20px;
        }

        .avatar-preview {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            object-fit: cover;
            display: none;
        }

        .input-icon {
            position: absolute;
            top: 50%;
            right: 1rem;
            transform: translateY(-50%);
            cursor: pointer;
            color: #64748b;
        }
    </style>
</head>
<body class="py-4">
    <div class="container">
        <div class="card shadow-lg mx-auto auth-card p-4 p-md-5">
            <div class="text-center mb-4">
                <h1 class="h4 fw-bold mb-1">Đăng ký tài khoản</h1>
                <p class="text-muted mb-0">Tạo tài khoản mới để bắt đầu đăng tin</p>
            </div>

            <form id="registerForm" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Họ và tên</label>
                        <input name="fullName" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Tên đăng nhập</label>
                        <input name="loginName" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input id="email" name="email" type="email" class="form-control" pattern="^[a-zA-Z0-9._%+-]+@@gmail\.com$" title="Vui lòng nhập email Gmail" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số điện thoại</label>
                        <input name="phone" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mật khẩu</label>
                        <div class="position-relative">
                            <input id="passwordInput" name="password" type="password" class="form-control pe-5" minlength="8" required />
                            <i class="fa-regular fa-eye input-icon toggle-password" data-target="#passwordInput"></i>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <div class="position-relative">
                            <input id="confirmPasswordInput" type="password" class="form-control pe-5" minlength="8" required />
                            <i class="fa-regular fa-eye input-icon toggle-password" data-target="#confirmPasswordInput"></i>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Hình đại diện (tuỳ chọn)</label>
                        <input name="avatar" id="avatar" type="file" accept="image/png,image/jpeg,image/webp,image/gif" class="form-control" />
                        <small class="text-muted">Hỗ trợ PNG/JPG/WEBP/GIF, tối đa 5MB.</small>
                        <img id="avatarPreview" class="avatar-preview mt-2" alt="Avatar preview" />
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input id="acceptTerms" class="form-check-input" type="checkbox" required />
                            <label class="form-check-label" for="acceptTerms">Tôi đồng ý với điều khoản sử dụng.</label>
                        </div>
                    </div>
                </div>

                <button id="submitBtn" type="submit" class="btn btn-primary w-100 mt-4">Đăng ký</button>
            </form>

            <p class="text-center mt-3 mb-0">
                Đã có tài khoản?
                <a class="fw-semibold text-decoration-none" href="/login">Đăng nhập</a>
            </p>
        </div>
    </div>

    <script>
        document.querySelectorAll('.toggle-password').forEach((icon) => {
            icon.addEventListener('click', () => {
                const input = document.querySelector(icon.dataset.target);
                input.type = input.type === 'password' ? 'text' : 'password';
                icon.classList.toggle('fa-eye');
                icon.classList.toggle('fa-eye-slash');
            });
        });

        const avatarInput = document.getElementById('avatar');
        const avatarPreview = document.getElementById('avatarPreview');
        const maxAvatarSize = 5 * 1024 * 1024;
        const allowedTypes = ['image/png', 'image/jpeg', 'image/webp', 'image/gif'];
        avatarInput.addEventListener('change', async (event) => {
            const file = event.target.files && event.target.files[0];

            if (!file) {
                avatarPreview.style.display = 'none';
                avatarPreview.removeAttribute('src');
                return;
            }

            if (!allowedTypes.includes(file.type)) {
                avatarInput.value = '';
                avatarPreview.style.display = 'none';
                avatarPreview.removeAttribute('src');
                await Swal.fire({ icon: 'warning', text: 'Avatar chỉ hỗ trợ PNG/JPG/WEBP/GIF.' }); 
                return;
            }

            if (file.size > maxAvatarSize) {
                avatarInput.value = '';
                avatarPreview.style.display = 'none';
                avatarPreview.removeAttribute('src');
                await Swal.fire({ icon: 'warning', text: 'Avatar vượt quá 5MB.' })
                return;
            }

            if (avatarPreview.dataset && avatarPreview.dataset.objectUrl) { URL.revokeObjectURL(avatarPreview.dataset.objectUrl); }

            const objectUrl = URL.createObjectURL(file);
            avatarPreview.src = objectUrl;
            avatarPreview.dataset.objectUrl = objectUrl;
            avatarPreview.style.display = 'block';
        });

        document.getElementById('registerForm').addEventListener('submit', async (event) => {
            event.preventDefault();

            const password = document.getElementById('passwordInput').value;
            const confirmPassword = document.getElementById('confirmPasswordInput').value;
            if (password !== confirmPassword) {
                Swal.fire({ icon: 'warning', text: 'Mật khẩu xác nhận không khớp.' });
                return;
            }

            const btn = document.getElementById('submitBtn');
            const original = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const form = document.getElementById('registerForm');
                const avatarFile = avatarInput.files?.[0];
                if (avatarFile && avatarFile.size > maxAvatarSize) {
                    Swal.fire({ icon: 'warning', text: 'Avatar vượt quá 5MB.' });
                    return;
                }

                const response = await fetch('/api/user/register', {
                    method: 'POST',
                    body: new FormData(form)
                });

                const data = await response.json();
                if (response.ok && data.success) {
                    await Swal.fire({ icon: 'success', text: data.message, timer: 1600, showConfirmButton: false });
                    window.location.href = data.redirectUrl ?? '/login';
                    return;
                }

                Swal.fire({ icon: 'error', text: data.message ?? 'Đăng ký thất bại.' });
            } catch {
                Swal.fire({ icon: 'error', text: 'Có lỗi xảy ra. Vui lòng thử lại.' });
            } finally {
                btn.disabled = false;
                btn.innerHTML = original;
            }
        });
    </script>
</body>
</html>
@model List<Tin_Tot_Website.Models.ProfileListingItemViewModel>
@{
    var placeholder = "https://placehold.co/300x220?text=Tin+Tot";
}

@if (Model.Any())
{
    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm">
                    <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? placeholder : item.ImageUrl)" class="card-img-top" style="height:180px;object-fit:cover" alt="@item.Title" />
                    <div class="card-body">
                        <h6 class="card-title text-truncate">@item.Title</h6>
                        <div class="text-danger fw-bold mb-2">@item.Price.ToString("N0") đ</div>
                        <div class="d-flex flex-wrap gap-2">
                            @if (item.Status == 1)
                            {
                                <button class="btn btn-warning btn-sm btn-mark-sold" data-id="@item.Id" type="button">✔️ Đã bán</button>
                                <button class="btn btn-info btn-sm btn-open-edit" data-id="@item.Id" data-category-id="@item.CategoryId" data-price="@item.Price" type="button">Sửa</button>
                            }
                            else if (item.Status == 0)
                            {
                                <span class="badge bg-primary">Đang chờ duyệt</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đã bán</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">Không có dữ liệu.</div>
}

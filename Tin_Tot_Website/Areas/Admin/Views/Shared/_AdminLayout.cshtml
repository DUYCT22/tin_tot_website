@using System.Security.Claims
@{
    var role = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var name = User.FindFirstValue(ClaimTypes.Name) ?? "Admin";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-shell" id="adminShell">
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-brand">Tin Tốt Admin</div>
            <nav class="nav flex-column">
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" href="/admin/dashboard"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
                <a class="nav-link" href="#"><i class="fa-solid fa-list-check"></i> Duyệt Tin</a>
                <a class="nav-link" href="#"><i class="fa-solid fa-eye"></i> Tin đang hiện</a>
                <a class="nav-link" href="#"><i class="fa-solid fa-users"></i> Người dùng</a>
                <a class="nav-link" href="#"><i class="fa-solid fa-image"></i> Banner</a>
                <a class="nav-link" href="#"><i class="fa-solid fa-folder-tree"></i> Danh mục</a>
            </nav>
        </aside>
        <div class="admin-main">
            <header class="admin-navbar">
                <button class="btn btn-sm btn-outline-secondary" id="toggleSidebar"><i class="fa-solid fa-bars"></i></button>
                <div class="d-flex align-items-center gap-3 ms-auto">
                    <div id="adminMessageActions" class="dropdown me-2">
                        <button class="btn btn-light position-relative" id="adminMessageBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside" type="button" title="Tin nhắn">
                            <i class="bi bi-chat-dots"></i>
                            <span id="adminMessageBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-0 admin-message-popup">
                            <div class="px-3 py-2 border-bottom"><strong>Tin nhắn</strong></div>
                            <div class="d-flex">
                                <div id="adminPopupConversationList" class="list-group list-group-flush admin-message-conversations"></div>
                                <div class="admin-message-chat d-flex flex-column">
                                    <div id="adminPopupChatHeader" class="px-3 py-2 border-bottom text-muted">Chọn cuộc trò chuyện</div>
                                    <div id="adminPopupChatBody" class="p-3 admin-message-chat-body"></div>
                                    <div class="p-2 border-top">
                                        <div class="d-flex gap-2 align-items-end">
                                            <textarea id="adminPopupChatInput" class="form-control" rows="1" placeholder="Nhập tin nhắn..."></textarea>
                                            <button id="adminPopupSendBtn" type="button" class="btn btn-primary">Gửi</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="dropdown">
                        <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                            <img id="adminNavbarAvatar" class="user-avatar" src="https://ui-avatars.com/api/?background=ffb703&color=fff&name=@Uri.EscapeDataString(name)" alt="avatar" />
                            <span>@name</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted">Role: @role</span></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><button class="dropdown-item text-danger" id="adminLogoutButton">Logout</button></li>
                        </ul>
                    </div>
                </div>
            </header>
            <main class="p-3">
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/admin/admin-layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>

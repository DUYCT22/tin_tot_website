@model Tin_Tot_Website.Areas.Admin.Models.CategoryManagementPageViewModel
@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-1"><i class="fa-solid fa-folder-tree me-2"></i>Quản lý Danh mục</h4>
        <p class="text-muted mb-0">Admin có thể thêm, cập nhật và xóa danh mục.</p>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header bg-light fw-semibold">Thêm danh mục mới</div>
    <div class="card-body">
        <form id="createCategoryForm" class="row g-3" enctype="multipart/form-data">
            <div class="col-md-4">
                <label class="form-label">Tên danh mục</label>
                <input name="name" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Danh mục cha</label>
                <select name="parentId" class="form-select">
                    <option value="">Không có</option>
                    @foreach (var parent in Model.ParentOptions)
                    {
                        <option value="@parent.Id">@parent.Name (@parent.Id)</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Ảnh</label>
                <input name="image" type="file" class="form-control" accept="image/*" />
            </div>
            <div class="col-md-1 d-grid align-items-end">
                <button class="btn btn-primary" type="submit">Thêm</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width:70px;">ID</th>
                <th style="min-width: 190px;">Ảnh</th>
                <th>Tên danh mục</th>
                <th style="width:120px;">Parent ID</th>
                <th style="min-width:160px;">Danh mục cha</th>
                <th style="width:140px;">Người tạo</th>
                <th style="width:140px;">Người sửa</th>
                <th style="width:170px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Categories)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.Image))
                        {
                            <img src="@item.Image" alt="category @item.Id" style="max-width: 90px; max-height: 70px; object-fit: cover;" class="rounded border" />
                        }
                    </td>
                    <td class="text-break">@item.Name</td>
                    <td>@(item.ParentId?.ToString() ?? "-")</td>
                    <td>@(item.ParentName ?? "-")</td>
                    <td>@(item.CreatedBy?.ToString() ?? "-")</td>
                    <td>@(item.UpdatedBy?.ToString() ?? "-")</td>
                    <td>
                        <div class="d-flex gap-2">
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary edit-category-btn"
                                    data-id="@item.Id"
                                    data-name="@item.Name"
                                    data-parent-id="@item.ParentId">
                                Sửa
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger delete-category-btn" data-id="@item.Id">Xóa</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Cập nhật danh mục</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editCategoryForm" class="row g-3" enctype="multipart/form-data">
                    <input type="hidden" name="id" />
                    <div class="col-12">
                        <label class="form-label">Tên danh mục</label>
                        <input name="name" class="form-control" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Danh mục cha</label>
                        <select name="parentId" class="form-select">
                            <option value="">Không có</option>
                            @foreach (var parent in Model.ParentOptions)
                            {
                                <option value="@parent.Id">@parent.Name (@parent.Id)</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Ảnh mới (không bắt buộc)</label>
                        <input name="image" type="file" class="form-control" accept="image/*" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary" id="saveCategoryBtn">Lưu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const authHeaders = () => {
                const token = localStorage.getItem('tin_tot_token');
                return token ? { Authorization: `Bearer ${token}` } : {};
            };

            const handleApi = async (url, options = {}) => {
                const response = await fetch(url, {
                    ...options,
                    headers: {
                        ...(options.headers || {}),
                        ...authHeaders()
                    }
                });

                const json = await response.json().catch(() => ({}));
                if (!response.ok) {
                    throw new Error(json.message || 'Có lỗi xảy ra.');
                }

                return json;
            };

            const createForm = document.getElementById('createCategoryForm');
            createForm?.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(createForm);
                if (!formData.get('parentId')) {
                    formData.set('parentId', '');
                }

                try {
                    await handleApi('/api/categories', { method: 'POST', body: formData });
                    location.reload();
                } catch (error) {
                    alert(error.message);
                }
            });

            const editForm = document.getElementById('editCategoryForm');
            const editModal = new bootstrap.Modal(document.getElementById('editCategoryModal'));

            document.querySelectorAll('.edit-category-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    editForm.elements['id'].value = btn.dataset.id;
                    editForm.elements['name'].value = btn.dataset.name ?? '';
                    editForm.elements['parentId'].value = btn.dataset.parentId ?? '';
                    editModal.show();
                });
            });

            document.getElementById('saveCategoryBtn')?.addEventListener('click', async () => {
                const id = editForm.elements['id'].value;
                const formData = new FormData(editForm);
                formData.delete('id');
                if (!formData.get('parentId')) {
                    formData.set('parentId', '');
                }

                try {
                    await handleApi(`/api/categories/${id}`, { method: 'PUT', body: formData });
                    location.reload();
                } catch (error) {
                    alert(error.message);
                }
            });

            document.querySelectorAll('.delete-category-btn').forEach(btn => {
                btn.addEventListener('click', async () => {
                    if (!confirm('Bạn có chắc muốn xóa danh mục này?')) return;

                    try {
                        await handleApi(`/api/categories/${btn.dataset.id}`, { method: 'DELETE' });
                        location.reload();
                    } catch (error) {
                        alert(error.message);
                    }
                });
            });
        })();
    </script>
}

@model Tin_Tot_Website.Areas.Admin.Models.AdminDashboardPageViewModel
@{
    ViewData["Title"] = "Dashboard";
    var role = Model.Role;
    bool isAdmin = role == 1;
    bool isListing = role == 2;
    bool isUser = role == 3;
}

<h4 class="mb-3">Dashboard quản trị</h4>
<div id="widgetGrid" class="row g-3">
    @if (isAdmin || isListing)
    {
        <div class="col-md-3"><div class="widget-card"><h6>Tổng số bài đăng</h6><p>@Model.Dashboard.TotalListings</p></div></div>
        <div class="col-md-3"><div class="widget-card"><h6>Bài đang hiển thị</h6><p>@Model.Dashboard.TotalActiveListings</p></div></div>
        <div class="col-md-3"><div class="widget-card"><h6>Bài đã bán</h6><p>@Model.Dashboard.TotalSoldListings</p></div></div>
        <div class="col-md-3"><div class="widget-card"><h6>Bài chờ duyệt</h6><p>@Model.Dashboard.TotalPendingListings</p></div></div>
        <div class="col-md-3"><div class="widget-card"><h6>Tăng trưởng bài đăng/tuần</h6><p>@Model.Dashboard.ListingGrowthPercent%</p></div></div>
    }

    @if (isAdmin || isUser)
    {
        <div class="col-md-3"><div class="widget-card"><h6>Tăng trưởng user mới/tuần</h6><p>@Model.Dashboard.NewUserGrowthPercent%</p></div></div>
    }

    @if (isAdmin)
    {
        <div class="col-md-3"><div class="widget-card"><h6>Danh mục con đang hiển thị</h6><p>@Model.Dashboard.VisibleLeafCategories</p></div></div>
        <div class="col-md-3"><div class="widget-card"><h6>Banner đang hiển thị</h6><p>@Model.Dashboard.VisibleBanners</p></div></div>
    }

    @if (isUser)
    {
        <div class="col-md-3"><div class="widget-card"><h6>User thường hoạt động</h6><p>@Model.Dashboard.ActiveMemberUsers</p></div></div>
        <div class="col-md-3"><div class="widget-card"><h6>User thường không hoạt động</h6><p>@Model.Dashboard.InactiveMemberUsers</p></div></div>
    }

    @if (isAdmin || isListing)
    {
        <div class="col-lg-4"><div class="widget-card"><h6>Biểu đồ tròn bài đăng</h6><canvas id="pieChart"></canvas></div></div>
        <div class="col-lg-4"><div class="widget-card"><h6>Bài đăng theo danh mục con</h6><canvas id="barChart"></canvas></div></div>
        <div class="col-lg-4"><div class="widget-card"><h6>Tăng trưởng bài đăng theo tháng</h6><canvas id="lineChart"></canvas></div></div>
    }

    @if (Model.QuickChatTargets.Any())
    {
        foreach (var chatTarget in Model.QuickChatTargets.Take(2))
        {
            <div class="col-md-6">
                <div class="widget-card quick-chat-card" data-receiver-key="@chatTarget.ReceiverKey" data-receiver-name="@chatTarget.ReceiverName">
                    <h6>@chatTarget.Title</h6>
                    <div class="small text-muted mb-2">Chat trực tiếp với @chatTarget.ReceiverName</div>
                    <div class="admin-quick-chat-body" style="height:260px;overflow:auto;background:#f8f9fa;"></div>
                    <div class="d-flex gap-2 align-items-end mt-2">
                        <textarea class="form-control admin-quick-chat-input" rows="1" placeholder="Nhập tin nhắn..."></textarea>
                        <button type="button" class="btn btn-primary admin-quick-chat-send">Gửi</button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script>
        const pieData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.ListingDistribution));
        const barData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.ListingsByCategory));
        const lineData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.MonthlyListingGrowth));
        const pick = (obj, ...keys) => {
            for (const key of keys) {
                if (obj && obj[key] !== undefined && obj[key] !== null) return obj[key];
            }
            return null;
        };
        if (document.getElementById('pieChart')) {
            new Chart(document.getElementById('pieChart'), {
                type: 'pie',
                data: {
                    labels: pieData.map(x => pick(x, 'label', 'Label')),
                    datasets: [{ data: pieData.map(x => pick(x, 'count', 'Count') || 0) }]
                }
            });

            new Chart(document.getElementById('barChart'), {
                type: 'bar',
                data: {
                    labels: barData.map(x => pick(x, 'categoryName', 'CategoryName')),
                    datasets: [{ data: barData.map(x => pick(x, 'count', 'Count') || 0) }]
                }
            });

            new Chart(document.getElementById('lineChart'), {
                type: 'line',
                data: {
                    labels: lineData.map(x => pick(x, 'monthLabel', 'MonthLabel')),
                    datasets: [{ data: lineData.map(x => pick(x, 'count', 'Count') || 0), fill: false }]
                }
            });
        }
        const chatCards = Array.from(document.querySelectorAll('.quick-chat-card'));
        const token = localStorage.getItem('tin_tot_token');
        const headers = () => ({ 'Content-Type': 'application/json', Authorization: `Bearer ${token}` });

        const timeFmt = (v) => {
            if (!v) return '';
            const d = new Date(v);
            if (Number.isNaN(d.getTime())) return '';
            return d.toLocaleString('vi-VN', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' });
        };

        const renderMessage = (card, m, myId) => {
            const body = card.querySelector('.admin-quick-chat-body');
            const isSelf = Number(m.senderId || m.SenderId) === myId;
            const wrap = document.createElement('div');
            wrap.className = `mb-2 d-flex ${isSelf ? 'justify-content-end' : 'justify-content-start'}`;

            const bubble = document.createElement('div');
            bubble.className = `p-2 rounded ${isSelf ? 'bg-primary text-white' : 'bg-white border'}`;
            bubble.style.maxWidth = '78%';
            bubble.innerHTML = `<div>${(m.content || m.Content || '').replace(/</g, '&lt;')}</div><small class='opacity-75'>${timeFmt(m.sentAt || m.SentAt)}</small>`;

            wrap.appendChild(bubble);
            body.appendChild(wrap);
        };

        const loadHistory = async (card) => {
            const receiverKey = card.dataset.receiverKey;
            const body = card.querySelector('.admin-quick-chat-body');
            const profile = JSON.parse(localStorage.getItem('tin_tot_user') || '{}');
            const myId = Number(profile.id || 0);

            const resp = await fetch(`/api/messages/history/${encodeURIComponent(receiverKey)}`, { headers: headers() });
            if (!resp.ok) return;
            const json = await resp.json();
            if (!json.success) return;

            body.innerHTML = '';
            json.data.forEach(m => renderMessage(card, m, myId));
            body.scrollTop = body.scrollHeight;
        };

        const initCard = (card) => {
            const input = card.querySelector('.admin-quick-chat-input');
            const sendBtn = card.querySelector('.admin-quick-chat-send');

            sendBtn?.addEventListener('click', async () => {
                const content = (input.value || '').trim();
                if (!content) return;

                const resp = await fetch('/api/messages/send', {
                    method: 'POST',
                    headers: headers(),
                    body: JSON.stringify({ receiverKey: card.dataset.receiverKey, content })
                });
                const json = await resp.json();
                if (!resp.ok || !json.success) return;

                input.value = '';
                await loadHistory(card);
            });

            input?.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
                    e.preventDefault();
                    sendBtn?.click();
                }
            });
        };

        chatCards.forEach(card => {
            initCard(card);
            loadHistory(card);
        });

        const connection = new signalR.HubConnectionBuilder().withUrl('/hubs/messages').withAutomaticReconnect().build();
        connection.on('ReceiveMessage', async () => {
            for (const card of chatCards) await loadHistory(card);
        });
        connection.start().catch(() => {});
        new Sortable(document.getElementById('widgetGrid'), { animation: 120 });
    </script>
}
